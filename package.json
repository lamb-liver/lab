{
  "name": "lab",
  "type": "module",
  "version": "1.2.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:force": "astro dev --force",
    "dev:recover": "npm run vite:deps:clean && npm run dev -- --force",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:content-audit": "vitest run src/content/contentAudit.test.ts",
    "test:works-smoke": "playwright test tests/work-integration.smoke.spec.ts",
    "test:seo-ux": "playwright test tests/seo-ux.spec.ts",
    "vite:deps:clean": "node -e \"require('node:fs').rmSync('node_modules/.vite/deps',{recursive:true,force:true})\"",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@astrojs/sitemap": "^3.7.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.5",
    "fuse.js": "^7.4.1",
    "katex": "^0.16.47",
    "p5": "^2.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@playwright/test": "^1.60.0",
    "@types/p5": "^1.7.7",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "vitest": "^4.1.7"
  }
}

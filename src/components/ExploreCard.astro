---
import '../styles/components/card.css';
import CardThumbFallback from './CardThumbFallback.astro';
import type { ExploreCategory } from '../content.config';
import { withBase } from '../lib/withBase';

interface Props {
  slug: string;
  title: string;
  description: string;
  category: ExploreCategory;
  coverImage?: string;
  featured?: boolean;
}

const { slug, title, description, category, coverImage, featured = false } = Astro.props;
---

<article
  class:list={['card', 'card--explore', { 'card--featured': featured }]}
  data-filter-item
  data-filter-category={category}
>
  <a href={withBase(`/explore/${slug}`)} class="card__link-wrap">
    <span class="card__kind card__kind--explore">探索</span>
    <div
      class:list={[
        'card__thumb',
        { 'card__thumb--has-cover': !!coverImage, 'card__thumb--fallback': !coverImage },
      ]}
      aria-hidden="true"
    >
      {
        coverImage ? (
          <img
            src={withBase(coverImage)}
            alt=""
            class="card__thumb-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <CardThumbFallback />
        )
      }
    </div>
    <div class="card__body">
      <div class="card__title-row">
        <h3 class="card__title">{title}</h3>
        {featured ? <span class="card__featured-label">精選</span> : null}
      </div>
      <div class="card__tags">
        <span class="card__tag">{category}</span>
      </div>
      <p class="card__desc">{description}</p>
    </div>
  </a>
</article>

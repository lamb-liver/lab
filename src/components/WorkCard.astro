---
import '../styles/components/card.css';
import CardThumbFallback from './CardThumbFallback.astro';
import { getCurveThumbnailSvg } from '../lib/curveThumbnail';
import { withBase } from '../lib/withBase';

interface Props {
  slug: string;
  title: string;
  description: string;
  tags: string[];
  featured?: boolean;
}

const { slug, title, description, tags, featured = false } = Astro.props;
const hasThumb = !!getCurveThumbnailSvg(slug);
const thumbSrc = withBase(`/thumbs/works/${slug}.svg`);
---

<article
  class:list={['card', 'card--work', { 'card--featured': featured }]}
  data-filter-item
  data-filter-tags={tags.join(',')}
  data-search-slug={slug}
>
  <a href={withBase(`/works/${slug}`)} class="card__link-wrap">
    <span class="card__kind card__kind--work">作品</span>
    <div
      class:list={[
        'card__thumb',
        { 'card__thumb--has-image': hasThumb, 'card__thumb--fallback': !hasThumb },
      ]}
      aria-hidden="true"
    >
      {
        hasThumb ? (
          <img
            src={thumbSrc}
            alt=""
            class="card__thumb-img"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <CardThumbFallback />
        )
      }
    </div>
    <div class="card__body">
      <div class="card__title-row">
        <h3 class="card__title">{title}</h3>
        {featured ? <span class="card__featured-label">精選</span> : null}
      </div>
      <div class="card__tags">
        {tags.map((tag) => <span class="card__tag">{tag}</span>)}
      </div>
      <p class="card__desc">{description}</p>
    </div>
  </a>
</article>

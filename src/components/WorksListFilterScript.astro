<script>
  import Fuse from 'fuse.js';
  import {
    applyWorksGridFilter,
    getFilterButton,
    readUrlParam,
    setActiveFilter,
    updateUrlParam,
  } from '../lib/listFilter.ts';

  type SearchRecord = { slug: string; title: string; description: string };

  function loadSearchIndex(): SearchRecord[] {
    const el = document.getElementById('works-search-index');
    if (!el?.textContent) return [];
    try {
      return JSON.parse(el.textContent) as SearchRecord[];
    } catch {
      return [];
    }
  }

  let cachedFuse: Fuse<SearchRecord> | null = null;

  function getFuse(): Fuse<SearchRecord> {
    if (!cachedFuse) {
      cachedFuse = new Fuse(loadSearchIndex(), {
        keys: [
          { name: 'title', weight: 0.65 },
          { name: 'description', weight: 0.35 },
        ],
        threshold: 0.38,
        ignoreLocation: true,
      });
    }
    return cachedFuse;
  }

  function searchSlugs(query: string): Set<string> {
    const trimmed = query.trim();
    if (!trimmed) return new Set();
    return new Set(getFuse().search(trimmed).map((result) => result.item.slug));
  }

  function attachWorksListFilter(root: HTMLElement): void {
    const bar = root.querySelector('[data-filter-bar]');
    const grid = root.querySelector('[data-card-grid]');
    const searchInput = root.querySelector('[data-works-search-input]') as HTMLInputElement | null;
    if (!bar || !grid || !searchInput) return;

    const tagParam = root.getAttribute('data-filter-param');
    const searchParam = root.getAttribute('data-search-param');
    const emptyEl = root.querySelector('[data-filter-empty]') as HTMLElement | null;

    let activeTag = '*';

    const applyAll = (): void => {
      const query = searchInput.value;
      const hasSearchQuery = query.trim().length > 0;
      const slugs = hasSearchQuery ? searchSlugs(query) : null;
      applyWorksGridFilter(
        grid as HTMLElement,
        activeTag,
        slugs,
        hasSearchQuery,
        emptyEl,
      );
    };

    const syncTagFromButton = (button: HTMLButtonElement): void => {
      activeTag = button.getAttribute('data-filter-value')?.trim().toLowerCase() || '*';
      setActiveFilter(bar, button);
    };

    const applyTagFromUrl = (): void => {
      const raw = readUrlParam(tagParam) || '*';
      const button = getFilterButton(bar, raw) ?? getFilterButton(bar, '*');
      if (!button) return;
      syncTagFromButton(button);
    };

    applyTagFromUrl();
    searchInput.value = readUrlParam(searchParam);
    applyAll();

    bar.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('button[data-filter-value]');
      if (!btn || !bar.contains(btn)) return;

      const rawValue = btn.getAttribute('data-filter-value')?.trim() ?? '*';
      syncTagFromButton(btn as HTMLButtonElement);
      applyAll();
      updateUrlParam(tagParam, rawValue === '*' ? '' : rawValue);
    });

    let searchDebounce: ReturnType<typeof setTimeout> | undefined;
    searchInput.addEventListener('input', () => {
      if (searchDebounce) clearTimeout(searchDebounce);
      searchDebounce = setTimeout(() => {
        applyAll();
        updateUrlParam(searchParam, searchInput.value);
      }, 120);
    });

    searchInput.addEventListener('search', () => {
      applyAll();
      updateUrlParam(searchParam, searchInput.value);
    });
  }

  document.querySelectorAll('[data-list-filter][data-search-param]').forEach((root) => {
    attachWorksListFilter(root as HTMLElement);
  });

  window.addEventListener('popstate', () => {
    document.querySelectorAll('[data-list-filter][data-search-param]').forEach((root) => {
      const filterRoot = root as HTMLElement;
      const searchInput = filterRoot.querySelector(
        '[data-works-search-input]',
      ) as HTMLInputElement | null;
      const bar = filterRoot.querySelector('[data-filter-bar]');
      const grid = filterRoot.querySelector('[data-card-grid]');
      if (!searchInput || !bar || !grid) return;

      const tagParam = filterRoot.getAttribute('data-filter-param');
      const searchParam = filterRoot.getAttribute('data-search-param');
      const raw = readUrlParam(tagParam) || '*';
      const button = getFilterButton(bar, raw) ?? getFilterButton(bar, '*');
      if (!button) return;

      const tagValue = button.getAttribute('data-filter-value')?.trim().toLowerCase() || '*';
      setActiveFilter(bar, button);
      searchInput.value = readUrlParam(searchParam);

      const query = searchInput.value;
      const hasSearchQuery = query.trim().length > 0;
      const slugs = hasSearchQuery ? searchSlugs(query) : null;
      applyWorksGridFilter(
        grid as HTMLElement,
        tagValue,
        slugs,
        hasSearchQuery,
        filterRoot.querySelector('[data-filter-empty]') as HTMLElement | null,
      );
    });
  });
</script>

---
import '../styles/components/nav.css';
import { isActivePath, withBase } from '../lib/withBase';

const links = [
  { path: '/works', label: '作品集' },
  { path: '/explore', label: '主題導覽' },
  { path: '/about', label: '關於' },
];

const pathname = Astro.url.pathname;
---

<header class="site-nav">
  <div class="site-nav__inner">
    <a href={withBase('/')} class="site-nav__logo">羊·實驗</a>

    <button
      class="site-nav__menu-button"
      type="button"
      aria-label="開啟選單"
      aria-expanded="false"
      aria-controls="site-nav-links"
      data-nav-toggle
    >
      <span class="site-nav__hamburger" aria-hidden="true">
        <span />
        <span />
        <span />
      </span>
    </button>

    <nav
      id="site-nav-links"
      class="site-nav__links"
      aria-label="主要導覽"
      data-nav-links
      data-open="false"
    >
      {
        links.map((link) => (
          <a
            href={withBase(link.path)}
            class:list={['site-nav__link', { 'is-active': isActivePath(link.path, pathname) }]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-nav-toggle]') as HTMLButtonElement | null;
  const links = document.querySelector('[data-nav-links]') as HTMLElement | null;

  const setOpen = (open: boolean) => {
    if (!links) return;
    links.dataset.open = open ? 'true' : 'false';
    toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle?.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
  };

  toggle?.addEventListener('click', () => {
    if (!links) return;
    setOpen(links.dataset.open !== 'true');
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    if (links?.dataset.open !== 'true') return;
    setOpen(false);
    toggle?.focus();
  });

  document.addEventListener('click', (event) => {
    if (!links || !toggle || links.dataset.open !== 'true') return;
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (links.contains(target) || toggle.contains(target)) return;
    setOpen(false);
  });
</script>

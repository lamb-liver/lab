<script>
  import {
    applyTagFilter,
    getFilterButton,
    readUrlParam,
    setActiveFilter,
    updateUrlParam,
  } from '../lib/listFilter.ts';

  function applyFilterState(root: HTMLElement, value: string): void {
    const bar = root.querySelector('[data-filter-bar]');
    const grid = root.querySelector('[data-card-grid]');
    if (!bar || !grid) return;

    const emptyEl = root.querySelector('[data-filter-empty]');
    const button = getFilterButton(bar, value) ?? getFilterButton(bar, '*');
    if (!button) return;

    const nextValue = button.getAttribute('data-filter-value')?.trim().toLowerCase() || '*';
    setActiveFilter(bar, button);
    applyTagFilter(grid as HTMLElement, nextValue, emptyEl as HTMLElement | null);
  }

  function attachListFilter(root: HTMLElement): void {
    const bar = root.querySelector('[data-filter-bar]');
    const grid = root.querySelector('[data-card-grid]');
    if (!bar || !grid) return;

    const filterParam = root.getAttribute('data-filter-param');

    applyFilterState(root, readUrlParam(filterParam) || '*');

    bar.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('button[data-filter-value]');
      if (!btn || !bar.contains(btn)) return;

      const rawValue = btn.getAttribute('data-filter-value')?.trim() ?? '*';
      const value = rawValue.toLowerCase();
      if (!value) return;

      setActiveFilter(bar, btn as HTMLButtonElement);
      applyTagFilter(
        grid as HTMLElement,
        value,
        root.querySelector('[data-filter-empty]') as HTMLElement | null,
      );
      updateUrlParam(filterParam, rawValue === '*' ? '' : rawValue);
    });
  }

  document
    .querySelectorAll('[data-list-filter]:not([data-search-param])')
    .forEach((root) => {
      attachListFilter(root as HTMLElement);
    });

  window.addEventListener('popstate', () => {
    document
      .querySelectorAll('[data-list-filter]:not([data-search-param])')
      .forEach((root) => {
        applyFilterState(
          root as HTMLElement,
          readUrlParam((root as HTMLElement).getAttribute('data-filter-param')) || '*',
        );
      });
  });
</script>

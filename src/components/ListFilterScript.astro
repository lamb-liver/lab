<script>
  function attachListFilter(root: HTMLElement) {
    const bar = root.querySelector('[data-filter-bar]');
    const grid = root.querySelector('[data-card-grid]');
    if (!bar || !grid) return;

    bar.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('button[data-filter-value]');
      if (!btn || !bar.contains(btn)) return;

      const value = btn.getAttribute('data-filter-value')?.trim().toLowerCase();
      if (!value) return;

      bar.querySelectorAll('button[data-filter-value]').forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });

      grid.querySelectorAll('[data-filter-item]').forEach((card) => {
        const el = card as HTMLElement;
        if (value === '*') {
          el.hidden = false;
          return;
        }

        const tags = el.getAttribute('data-filter-tags');
        const category = el.getAttribute('data-filter-category');
        const tokens = (tags ?? category ?? '')
          .split(',')
          .map((s) => s.trim())
          .filter(Boolean)
          .map((s) => s.toLowerCase());

        el.hidden = !tokens.includes(value);
      });
    });
  }

  document.querySelectorAll('[data-list-filter]').forEach((root) => {
    attachListFilter(root as HTMLElement);
  });
</script>

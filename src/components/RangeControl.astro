---
import '../styles/components/range.css';

interface Props {
  id: string;
  label: string;
  min?: number;
  max?: number;
  value?: number;
  step?: number;
}

const {
  id,
  label,
  min = 0,
  max = 100,
  value = 50,
  step = 1,
} = Astro.props;
---

<div class="control-field">
  <label for={id}>{label}</label>
  <div class="range-wrap">
    <input
      type="range"
      id={id}
      class="range"
      min={min}
      max={max}
      value={value}
      step={step}
    />
  </div>
</div>

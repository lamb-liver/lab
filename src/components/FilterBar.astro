---
import '../styles/components/filter.css';

interface Props {
  options: string[];
  ariaLabel: string;
}

const { options, ariaLabel } = Astro.props;
const items = ['全部', ...options];
---

<div class="filter-scroll" data-filter-scroll>
  <div class="filter-bar" data-filter-bar role="group" aria-label={ariaLabel}>
    {
      items.map((item, i) => (
        <button
          type="button"
          class:list={['filter-btn', { 'is-active': i === 0 }]}
          data-filter-value={item === '全部' ? '*' : item}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          {item}
        </button>
      ))
    }
  </div>
</div>

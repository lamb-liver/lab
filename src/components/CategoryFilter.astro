---
import '../styles/components/filter.css';

interface Props {
  categories: string[];
}

const { categories } = Astro.props;
const items = ['全部', ...categories];
---

<div class="filter-scroll" data-filter-scroll>
  <div class="filter-bar" data-filter-bar role="group" aria-label="主題分類篩選">
    {
      items.map((category, i) => (
        <button
          type="button"
          class:list={['filter-btn', { 'is-active': i === 0 }]}
          data-filter-value={category === '全部' ? '*' : category}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          {category}
        </button>
      ))
    }
  </div>
</div>

---
import '../styles/components/canvas.css';

interface Props {
  class?: string;
}

const { class: className = 'canvas-placeholder' } = Astro.props;
const message = '此頁目前提供文字說明';
---

<div
  class={className}
  role="region"
  aria-label={message}
>
  <p class="canvas-placeholder__text">{message}</p>
</div>

---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/scrollbar.css';
import '../styles/layout.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { pagePathForSite, withBase } from '../lib/withBase';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterCard?: 'summary' | 'summary_large_image';
}

const {
  title,
  description = '羊·實驗 — 數學與演算法的視覺化實驗',
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = 'website',
  twitterCard = 'summary_large_image',
} = Astro.props;
const fullTitle = title === '羊·實驗' ? title : `${title} · 羊·實驗`;
const site = Astro.site ?? Astro.url;
const canonicalURL = canonical ?? new URL(pagePathForSite(Astro.url.pathname), site).href;
const resolvedOgTitle = ogTitle ?? fullTitle;
const resolvedOgDescription = ogDescription ?? description;
const ogImageURL = new URL(ogImage ? withBase(ogImage) : withBase('/og-default.png'), site).href;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Nav />
    <main class="page-enter">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        var ZONE = 14;
        var root = document.documentElement;
        var inside = false;
        document.addEventListener(
          'mousemove',
          function (e) {
            var near =
              e.clientX >= window.innerWidth - ZONE && e.clientY > 0;
            if (near === inside) return;
            inside = near;
            root.classList.toggle('scrollbar-hover', near);
          },
          { passive: true }
        );
        document.addEventListener('mouseleave', function () {
          inside = false;
          root.classList.remove('scrollbar-hover');
        });
      })();
    </script>
  </body>
</html>

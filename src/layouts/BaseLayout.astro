---
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/scrollbar.css';
import '../styles/layout.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_OG_IMAGE, DEFAULT_OG_IMAGE_ALT, isDefaultOgImage } from '../lib/defaultOg';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogType?: string;
  twitterCard?: 'summary' | 'summary_large_image';
  structuredData?: Array<Record<string, unknown>>;
}

const {
  title,
  description = '羊·實驗 — 數學與演算法的視覺化實驗',
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  ogImageAlt,
  ogImageWidth,
  ogImageHeight,
  ogType = 'website',
  twitterCard = 'summary_large_image',
  structuredData = [],
} = Astro.props;
const fullTitle = title === '羊·實驗' ? title : `${title} · 羊·實驗`;
const site = Astro.site ?? Astro.url;
const canonicalURL = canonical ?? new URL(Astro.url.pathname || '/', site).href;
const resolvedOgTitle = ogTitle ?? fullTitle;
const resolvedOgDescription = ogDescription ?? description;
const usesDefaultOgImage = isDefaultOgImage(ogImage);
const resolvedOgImagePath = usesDefaultOgImage ? DEFAULT_OG_IMAGE : ogImage!;
const ogImageURL = new URL(resolvedOgImagePath, site).href;
const resolvedOgImageAlt =
  ogImageAlt ?? (usesDefaultOgImage ? DEFAULT_OG_IMAGE_ALT : resolvedOgTitle);
const inferredOgImageSize =
  usesDefaultOgImage || resolvedOgImagePath.startsWith('/og/works/')
    ? { width: ogImageWidth ?? 1200, height: ogImageHeight ?? 630 }
    : ogImageWidth && ogImageHeight
      ? { width: ogImageWidth, height: ogImageHeight }
      : null;
const siteRootURL = new URL('/', site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: '羊·實驗',
    url: siteRootURL,
    inLanguage: 'zh-Hant',
  },
  ...structuredData,
].map((data) => JSON.stringify(data).replace(/</g, '\\u003c'));
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/lab-favicon-eb-garamond.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="羊·實驗" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    {
      inferredOgImageSize ? (
        <>
          <meta property="og:image:width" content={String(inferredOgImageSize.width)} />
          <meta property="og:image:height" content={String(inferredOgImageSize.height)} />
        </>
      ) : null
    }
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={resolvedOgImageAlt} />
    {jsonLd.map((json) => <script type="application/ld+json" set:html={json} />)}
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Nav />
    <main class="page-enter">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        var ZONE = 14;
        var root = document.documentElement;
        var inside = false;
        document.addEventListener(
          'mousemove',
          function (e) {
            var near =
              e.clientX >= window.innerWidth - ZONE && e.clientY > 0;
            if (near === inside) return;
            inside = near;
            root.classList.toggle('scrollbar-hover', near);
          },
          { passive: true }
        );
        document.addEventListener('mouseleave', function () {
          inside = false;
          root.classList.remove('scrollbar-hover');
        });
      })();
    </script>
  </body>
</html>

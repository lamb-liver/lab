---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CanvasPlaceholder from '../../components/CanvasPlaceholder.astro';
import ExamInteractiveStage from '../../components/exam/ExamInteractiveStage';
import { getCollection, render } from 'astro:content';
import { getStaticPathsFromCollection } from '../../content/utils';
import { isExamInteractive } from '../../exam/interactiveRegistry';
import 'katex/dist/katex.min.css';
import '../../styles/components/canvas.css';
import '../../styles/prose.css';
import '../../styles/pages/explore-detail.css';
import '../../styles/pages/exam-detail.css';
import '../../styles/components/explore-touch.css';
import '../../styles/components/explore/explore-stage.css';

export async function getStaticPaths() {
  const exam = await getCollection('exam');
  return getStaticPathsFromCollection(exam, { includeDraft: import.meta.env.DEV });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const interactive = isExamInteractive(entry.id);
const { subject, year, questionType, questionNo } = entry.data;
const sourceLabel = `${year} ${subject}・${questionType}${questionNo}`;
const ogImage = entry.data.coverImage;
const site = Astro.site ?? Astro.url;
const siteRoot = new URL('/', site).href;
const examUrl = new URL('/exam', site).href;
const articleUrl = new URL(`/exam/${entry.id}`, site).href;
const imageUrl = ogImage ? new URL(ogImage, site).href : undefined;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: siteRoot },
      { '@type': 'ListItem', position: 2, name: '試題視覺化', item: examUrl },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: articleUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    ...(imageUrl ? { image: imageUrl } : {}),
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    inLanguage: 'zh-Hant',
    datePublished: entry.data.date.toISOString(),
  },
];

const works = await getCollection('works');
const explore = await getCollection('explore');
const relatedWorks = entry.data.relatedWorks
  .map((slug) => works.find((work) => work.id === slug && (entry.data.draft || !work.data.draft)))
  .filter((work) => work !== undefined);
const relatedExplore = entry.data.relatedExplore
  .map((slug) => explore.find((topic) => topic.id === slug && (entry.data.draft || !topic.data.draft)))
  .filter((topic) => topic !== undefined);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  ogImageAlt={entry.data.title}
  ogType="article"
  structuredData={structuredData}
>
  <div class={`container explore-detail${interactive ? ' explore-detail--interactive' : ''}`}>
    <div class="detail-top-nav">
      <Breadcrumb
        items={[
          { label: '首頁', href: '/' },
          { label: '試題視覺化', href: '/exam' },
          { label: entry.data.title },
        ]}
      />
      <a href="/exam" class="back-link back-link--top">← 返回試題視覺化</a>
    </div>

    <header class="page-header">
      <p class="exam-source-label">{sourceLabel}</p>
      <h1>{entry.data.title}</h1>
      <div class="tag-list">
        <span class="tag">{entry.data.unit}</span>
        {entry.data.concepts.map((concept) => <span class="tag">{concept}</span>)}
      </div>
      {
        entry.data.sourceUrl ? (
          <p class="exam-source-links">
            <a href={entry.data.sourceUrl} rel="noopener noreferrer" target="_blank">
              大考中心原卷
            </a>
            {entry.data.analysisUrl ? (
              <a href={entry.data.analysisUrl} rel="noopener noreferrer" target="_blank">
                試題解析
              </a>
            ) : null}
          </p>
        ) : null
      }
    </header>

    {
      interactive ? (
        <ExamInteractiveStage client:only="react" slug={entry.id}>
          <div
            slot="fallback"
            class="interactive-loading interactive-loading--explore"
            role="status"
            aria-live="polite"
            aria-label="互動內容載入中"
          >
            <span class="interactive-loading__mark"></span>
          </div>
        </ExamInteractiveStage>
      ) : (
        <CanvasPlaceholder class="interactive-canvas" />
      )
    }

    <article class="prose">
      <Content />
    </article>

    {
      relatedExplore.length > 0 || relatedWorks.length > 0 ? (
        <section class="exam-related" aria-label="延伸閱讀">
          <h2>延伸</h2>
          <ul>
            {relatedExplore.map((topic) => (
              <li>
                <a href={`/explore/${topic.id}`}>主題導覽：{topic.data.title}</a>
              </li>
            ))}
            {relatedWorks.map((work) => (
              <li>
                <a href={`/works/${work.id}`}>作品：{work.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ) : null
    }

    <a href="/exam" class="back-link">← 返回試題視覺化</a>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CanvasPlaceholder from '../../components/CanvasPlaceholder.astro';
import ExploreInteractiveStage from '../../components/explore/ExploreInteractiveStage';
import { getCollection, render } from 'astro:content';
import {
  getCollectionPagerNeighbors,
  getStaticPathsFromCollection,
} from '../../content/utils';
import { isExploreInteractive } from '../../explore/interactiveRegistry';
import 'katex/dist/katex.min.css';
import '../../styles/components/canvas.css';
import '../../styles/prose.css';
import '../../styles/pages/explore-detail.css';
import '../../styles/components/explore-touch.css';
import '../../styles/components/explore/explore-stage.css';
import '../../styles/components/explore/explore-toolbar.css';

export async function getStaticPaths() {
  const explore = await getCollection('explore');
  return getStaticPathsFromCollection(explore, { includeDraft: import.meta.env.DEV });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const interactive = isExploreInteractive(entry.id);
const { previous: previousExplore, next: nextExplore } = getCollectionPagerNeighbors(
  await getCollection('explore'),
  entry.id,
);
const ogImage = entry.data.coverImage;
const site = Astro.site ?? Astro.url;
const siteRoot = new URL('/', site).href;
const exploreUrl = new URL('/explore', site).href;
const articleUrl = new URL(`/explore/${entry.id}`, site).href;
const imageUrl = ogImage ? new URL(ogImage, site).href : undefined;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: siteRoot },
      { '@type': 'ListItem', position: 2, name: '主題導覽', item: exploreUrl },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: articleUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    ...(imageUrl ? { image: imageUrl } : {}),
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    inLanguage: 'zh-Hant',
    datePublished: entry.data.date.toISOString(),
  },
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  ogImageAlt={entry.data.title}
  ogType="article"
  structuredData={structuredData}
>
  <div class={`container explore-detail${interactive ? ' explore-detail--interactive' : ''}`}>
    <div class="detail-top-nav">
      <Breadcrumb
        items={[
          { label: '首頁', href: '/' },
          { label: '主題導覽', href: '/explore' },
          { label: entry.data.title },
        ]}
      />
      <a href="/explore" class="back-link back-link--top">← 返回主題導覽</a>
    </div>

    <header class="page-header">
      <h1>{entry.data.title}</h1>
      <div class="tag-list">
        <span class="tag">{entry.data.category}</span>
      </div>
    </header>

    {
      interactive ? (
        <ExploreInteractiveStage client:only="react" slug={entry.id}>
          <div
            slot="fallback"
            class="interactive-loading interactive-loading--explore"
            role="status"
            aria-live="polite"
            aria-label="互動內容載入中"
          >
            <span class="interactive-loading__mark"></span>
          </div>
        </ExploreInteractiveStage>
      ) : (
        <CanvasPlaceholder class="interactive-canvas" variant="unavailable" />
      )
    }

    <article class="prose">
      <Content />
    </article>

    <nav class="explore-detail__pager" aria-label="主題文章導覽">
      {
        previousExplore ? (
          <a href={`/explore/${previousExplore.id}`} class="explore-detail__pager-link">
            <span>較早一篇</span>
            <strong>{previousExplore.data.title}</strong>
          </a>
        ) : (
          <span
            class="explore-detail__pager-link explore-detail__pager-link--disabled"
            aria-disabled="true"
            aria-label="沒有較早一篇"
          >
            <span>較早一篇</span>
            <strong>無</strong>
          </span>
        )
      }
      {
        nextExplore ? (
          <a href={`/explore/${nextExplore.id}`} class="explore-detail__pager-link explore-detail__pager-link--next">
            <span>較新一篇</span>
            <strong>{nextExplore.data.title}</strong>
          </a>
        ) : (
          <span
            class="explore-detail__pager-link explore-detail__pager-link--disabled explore-detail__pager-link--next"
            aria-disabled="true"
            aria-label="沒有較新一篇"
          >
            <span>較新一篇</span>
            <strong>無</strong>
          </span>
        )
      }
    </nav>

    <a href="/explore" class="back-link">← 返回主題導覽</a>
  </div>
</BaseLayout>

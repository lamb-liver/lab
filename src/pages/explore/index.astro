---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import ExploreCard from '../../components/ExploreCard.astro';
import ListFilterScript from '../../components/ListFilterScript.astro';
import { getCollection } from 'astro:content';
import { collectExploreCategories, getPublishedAsc } from '../../content/utils';

const explore = getPublishedAsc(await getCollection('explore'));
const categoryOptions = collectExploreCategories(explore);
---

<BaseLayout
  title="視覺化"
  description="跨概念主題式導覽：從一個大概念出發，串起多個互動實驗與觀察重點。"
  ogImage="/og-default.png"
  ogType="website"
>
  <div class="container" data-list-filter data-filter-param="category">
    <header class="page-header">
      <span class="section-badge section-badge--explore">互動探索</span>
      <h1>視覺化</h1>
      <p class="page-lead">
        跨概念的主題式導覽：從一個大概念出發，串起多個互動實驗與觀察重點。
      </p>
    </header>

    <CategoryFilter categories={categoryOptions} />

    <div class="card-grid" data-card-grid>
      {
        explore.map((entry) => (
          <ExploreCard
            slug={entry.id}
            title={entry.data.title}
            description={entry.data.description}
            category={entry.data.category}
            coverImage={entry.data.coverImage}
          />
        ))
      }
    </div>

    <p class="filter-empty" data-filter-empty hidden>目前無符合此分類的內容</p>
  </div>
  <ListFilterScript />
</BaseLayout>

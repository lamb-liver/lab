---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCanvasShell from '../components/HeroCanvasShell.astro';
import WorkCard from '../components/WorkCard.astro';
import ExploreCard from '../components/ExploreCard.astro';
import { getCollection } from 'astro:content';
import { exploreInteractiveSlugs } from '../explore/interactiveRegistry';
import {
  excludeEntryIds,
  getFeaturedInteractive,
  getPublishedInteractive,
} from '../content/utils';
import { workInteractiveSlugs } from '../works/interactiveRegistry';
import { withBase } from '../lib/withBase';
import '../styles/pages/home.css';

const works = await getCollection('works');
const explore = await getCollection('explore');

const featuredWorks = getFeaturedInteractive(works, workInteractiveSlugs, 2);
const featuredExplore = getFeaturedInteractive(explore, exploreInteractiveSlugs, 1);
const featuredIds = new Set([
  ...featuredWorks.map((entry) => entry.id),
  ...featuredExplore.map((entry) => entry.id),
]);

const latestWorks = excludeEntryIds(
  getPublishedInteractive(works, workInteractiveSlugs, 6),
  featuredIds,
).slice(0, 3);
const latestExplore = excludeEntryIds(
  getPublishedInteractive(explore, exploreInteractiveSlugs, 6),
  featuredIds,
).slice(0, 3);
---

<BaseLayout
  title="羊·實驗"
  description="羊·實驗：以互動視覺化與 generative art 呈現數學公式、曲線與演算法。作品集深度展示單一主題，視覺化串連跨概念實驗。"
>
  <section class="hero-section">
    <HeroCanvasShell />
    <div class="hero-content">
      <h1>羊·實驗</h1>
      <p>數學與演算法的實驗</p>
    </div>
  </section>

  <section class="section home-nav-section">
    <div class="container">
      <div class="home-nav-grid">
        <a href={withBase('/works')} class="home-nav-card home-nav-card--work">
          <span class="section-badge section-badge--work">深度作品</span>
          <h2 class="home-nav-card__title">作品集</h2>
          <p class="home-nav-card__desc">
            每篇聚焦一個數學對象：公式、可調參數互動，以及完整視覺解釋。
          </p>
          <span class="home-nav-card__cta">進入作品集 →</span>
        </a>
        <a href={withBase('/explore')} class="home-nav-card home-nav-card--explore">
          <span class="section-badge section-badge--explore">互動視覺化</span>
          <h2 class="home-nav-card__title">主題導覽</h2>
          <p class="home-nav-card__desc">
            從一個大概念出發，串起多個互動實驗與觀察重點。
          </p>
          <span class="home-nav-card__cta">進入主題導覽 →</span>
        </a>
      </div>
    </div>
  </section>

  {
    featuredWorks.length > 0 || featuredExplore.length > 0 ? (
      <section class="section">
        <div class="container">
          <div class="home-section-header">
            <div class="home-section-heading">
              <h2 class="section-title">精選</h2>
              <p class="home-section-desc">策展推薦：視覺衝擊力與互動完整度優先。</p>
            </div>
          </div>

          <div class="card-grid home-featured-grid">
            {featuredWorks.map((entry) => (
              <WorkCard
                slug={entry.id}
                title={entry.data.title}
                description={entry.data.description}
                tags={entry.data.tags}
                featured
              />
            ))}
            {featuredExplore.map((entry) => (
              <ExploreCard
                slug={entry.id}
                title={entry.data.title}
                description={entry.data.description}
                category={entry.data.category}
                coverImage={entry.data.coverImage}
                featured
              />
            ))}
          </div>
        </div>
      </section>
    ) : null
  }

  <section class="section">
    <div class="container">
      <div class="home-section-header">
        <div class="home-section-heading">
          <h2 class="section-title">最新作品</h2>
          <p class="home-section-desc">
            每篇聚焦一個數學對象：公式、可調參數互動，以及完整視覺解釋。
          </p>
        </div>
        <a href={withBase('/works')} class="home-section-link">查看全部 →</a>
      </div>
      <div class="card-grid">
        {
          latestWorks.map((entry) => (
            <WorkCard
              slug={entry.id}
              title={entry.data.title}
              description={entry.data.description}
              tags={entry.data.tags}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="home-section-header">
        <div class="home-section-heading">
          <h2 class="section-title">最新主題</h2>
          <p class="home-section-desc">
            依主題進入數學概念，用互動視覺化建立核心圖像。
          </p>
        </div>
        <a href={withBase('/explore')} class="home-section-link">查看全部 →</a>
      </div>
      <div class="home-topic-list">
        {
          latestExplore.map((entry) => (
            <article class="home-topic-item">
              <div class="home-topic-item__meta">
                <span class="section-badge section-badge--explore">互動視覺化</span>
                <span class="home-topic-item__category">{entry.data.category}</span>
              </div>
              <h3 class="home-topic-item__title">
                <a href={withBase(`/explore/${entry.id}`)}>{entry.data.title}</a>
              </h3>
              <p class="home-topic-item__desc">{entry.data.description}</p>
              <a class="home-topic-item__link" href={withBase(`/explore/${entry.id}`)}>
                進入主題 →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCanvasShell from '../components/HeroCanvasShell.astro';
import WorkCard from '../components/WorkCard.astro';
import ExploreCard from '../components/ExploreCard.astro';
import { getCollection } from 'astro:content';
import { exploreInteractiveSlugs } from '../explore/interactiveRegistry';
import { getPublishedInteractive } from '../content/utils';
import { workInteractiveSlugs } from '../works/interactiveRegistry';
import { withBase } from '../lib/withBase';
import '../styles/pages/home.css';

const works = await getCollection('works');
const explore = await getCollection('explore');

const latestWorks = getPublishedInteractive(works, workInteractiveSlugs, 3);
const latestExplore = getPublishedInteractive(explore, exploreInteractiveSlugs, 3);
---

<BaseLayout
  title="羊·實驗"
  description="羊·實驗：以互動視覺化與 generative art 呈現數學公式、曲線與演算法。作品集深度展示單一主題，視覺化串連跨概念實驗。"
>
  <section class="hero-section">
    <HeroCanvasShell />
    <div class="hero-content">
      <h1>羊·實驗</h1>
      <p>數學與演算法的實驗</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="home-section-header">
        <div class="home-section-heading">
          <h2 class="section-title">最新作品</h2>
          <p class="home-section-desc">
            每篇聚焦一個數學對象：公式、可調參數互動，以及完整視覺解釋。
          </p>
        </div>
        <a href={withBase('/works')} class="home-section-link">查看全部 →</a>
      </div>
      <div class="card-grid">
        {
          latestWorks.map((entry) => (
            <WorkCard
              slug={entry.id}
              title={entry.data.title}
              description={entry.data.description}
              tags={entry.data.tags}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="home-section-header">
        <div class="home-section-heading">
          <h2 class="section-title">最新視覺化</h2>
          <p class="home-section-desc">
            從一個大概念出發，串起多個互動實驗與觀察重點。
          </p>
        </div>
        <a href={withBase('/explore')} class="home-section-link">查看全部 →</a>
      </div>
      <div class="card-grid">
        {
          latestExplore.map((entry) => (
            <ExploreCard
              slug={entry.id}
              title={entry.data.title}
              description={entry.data.description}
              category={entry.data.category}
              coverImage={entry.data.coverImage}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

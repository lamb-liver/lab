---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListSearchFilterScript from '../../components/ListSearchFilterScript.astro';
import TagFilter from '../../components/TagFilter.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getCollection } from 'astro:content';
import { collectWorkTags, getPublishedAsc } from '../../content/utils';
import { serializeSearchIndex } from '../../lib/listFilter';
import { siteSeo } from '../../lib/seoCopy';
import '../../styles/components/list-search.css';

const works = getPublishedAsc(await getCollection('works'));
const tagOptions = collectWorkTags(works);
const searchIndex = works.map((entry) => ({
  slug: entry.id,
  title: entry.data.title,
  description: entry.data.description,
}));
---

<BaseLayout title={siteSeo.works.title} description={siteSeo.works.description} ogType="website">
  <div
    class="container"
    data-list-filter
    data-filter-param="tag"
    data-search-param="q"
    data-search-index-id="works-search-index"
  >
    <header class="page-header">
      <span class="section-badge section-badge--work">深度作品</span>
      <h1>作品集</h1>
      <p class="page-lead">
        單一主題的深度展示：每篇聚焦一個數學對象，包含公式、互動與視覺解釋。
      </p>
    </header>

    <section class="list-controls" aria-label="作品列表工具">
      <div class="list-controls__top">
        <div class="list-search">
          <label class="list-search__label" for="works-search-input">搜尋作品</label>
          <input
            id="works-search-input"
            class="list-search__input"
            type="search"
            name="q"
            placeholder="搜尋標題或描述…"
            autocomplete="off"
            spellcheck="false"
            data-works-search-input
            data-list-search-input
          />
        </div>

        <p class="list-filter-count" data-filter-count aria-live="polite">共 {works.length} 篇</p>
      </div>

      <TagFilter tags={tagOptions} />
    </section>

    <script
      type="application/json"
      id="works-search-index"
      set:html={serializeSearchIndex(searchIndex)}
    />

    <div class="card-grid" data-card-grid>
      {
        works.map((entry) => (
          <WorkCard
            slug={entry.id}
            title={entry.data.title}
            description={entry.data.description}
            tags={entry.data.tags}
          />
        ))
      }
    </div>

    <p class="filter-empty" data-filter-empty hidden>
      找不到符合的作品
      <button type="button" class="filter-empty__clear" data-filter-clear>清除篩選</button>
    </p>
  </div>
  <ListSearchFilterScript />
</BaseLayout>

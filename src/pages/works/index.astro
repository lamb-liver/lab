---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListFilterScript from '../../components/ListFilterScript.astro';
import TagFilter from '../../components/TagFilter.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getCollection } from 'astro:content';
import { collectWorkTags, getPublishedAsc } from '../../content/utils';

const works = getPublishedAsc(await getCollection('works'));
const tagOptions = collectWorkTags(works);
---

<BaseLayout
  title="作品集"
  description="單一數學對象的深度作品集：每篇含公式、可調參數互動與完整 Markdown 說明。"
>
  <div class="container" data-list-filter>
    <header class="page-header">
      <h1>作品集</h1>
      <p class="page-lead">
        單一主題的深度展示：每篇聚焦一個數學對象，包含公式、互動與視覺解釋。
      </p>
    </header>

    <TagFilter tags={tagOptions} />

    <div class="card-grid" data-card-grid>
      {
        works.map((entry) => (
          <WorkCard
            slug={entry.id}
            title={entry.data.title}
            description={entry.data.description}
            tags={entry.data.tags}
          />
        ))
      }
    </div>

    <p class="filter-empty" data-filter-empty hidden>目前無符合此標籤的作品</p>
  </div>
  <ListFilterScript />
</BaseLayout>

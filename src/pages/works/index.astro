---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListFilterScript from '../../components/ListFilterScript.astro';
import TagFilter from '../../components/TagFilter.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getCollection } from 'astro:content';
import { collectWorkTags, getPublishedAsc } from '../../content/utils';

const works = getPublishedAsc(await getCollection('works'));
const tagOptions = collectWorkTags(works);
---

<BaseLayout title="作品集">
  <div class="container" data-list-filter>
    <header class="page-header">
      <h1>作品集</h1>
    </header>

    <TagFilter tags={tagOptions} />

    <div class="card-grid" data-card-grid>
      {
        works.map((entry) => (
          <WorkCard
            slug={entry.id}
            title={entry.data.title}
            description={entry.data.description}
            tags={entry.data.tags}
          />
        ))
      }
    </div>

    <p class="filter-empty" data-filter-empty hidden>目前無符合此標籤的作品</p>
  </div>
  <ListFilterScript />
</BaseLayout>

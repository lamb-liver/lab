---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CanvasPlaceholder from '../../components/CanvasPlaceholder.astro';
import WorkInteractiveStage from '../../components/works/WorkInteractiveStage';
import { getCollection, render } from 'astro:content';
import {
  getCollectionPagerNeighbors,
  getStaticPathsFromCollection,
} from '../../content/utils';
import {
  isWorkInteractive,
  workControlsMountId,
} from '../../works/interactiveRegistry';
import { getWorkOgImagePath } from '../../lib/workOgImage';
import 'katex/dist/katex.min.css';
import '../../styles/prose.css';
import '../../styles/pages/work-detail.css';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return getStaticPathsFromCollection(works);
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const interactive = isWorkInteractive(entry.id);
const { previous: previousWork, next: nextWork } = getCollectionPagerNeighbors(
  await getCollection('works'),
  entry.id,
);
const ogImage = entry.data.ogImage ?? getWorkOgImagePath(entry.id);
const site = Astro.site ?? Astro.url;
const siteRoot = new URL('/', site).href;
const worksUrl = new URL('/works', site).href;
const articleUrl = new URL(`/works/${entry.id}`, site).href;
const imageUrl = new URL(ogImage, site).href;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: siteRoot },
      { '@type': 'ListItem', position: 2, name: '作品集', item: worksUrl },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: articleUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    image: imageUrl,
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    inLanguage: 'zh-Hant',
    datePublished: entry.data.date.toISOString(),
  },
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  ogImageAlt={entry.data.title}
  ogType="article"
  structuredData={structuredData}
>
  <div class="container detail-top-nav">
    <Breadcrumb
      items={[
        { label: '首頁', href: '/' },
        { label: '作品集', href: '/works' },
        { label: entry.data.title },
      ]}
    />
    <a href="/works" class="back-link back-link--top">← 返回作品集</a>
  </div>

  <header class="container work-detail__header">
    <h1 class="work-detail__header-title">{entry.data.title}</h1>
    {
      entry.data.tags.length > 0 ? (
        <div class="work-detail__header-tags">
          {entry.data.tags.map((tag) => (
            <span class="work-detail__header-tag">{tag}</span>
          ))}
        </div>
      ) : null
    }
  </header>

  {
    interactive ? (
      <div class="work-detail__stage">
        <details class="work-detail__controls" data-work-controls open>
          <summary class="work-detail__controls-toggle">
            <span class="work-detail__controls-toggle-label">
              <span class="work-detail__controls-toggle-text">調整參數</span>
              <span class="work-detail__controls-toggle-text--open">收合參數</span>
              <span class="work-detail__controls-toggle-hint">點開後向下滑動以調整</span>
            </span>
          </summary>
          <aside
            class="controls-panel controls-panel--stage"
            id={workControlsMountId(entry.id)}
            aria-label="參數控制區"
          />
        </details>
        <div class="work-detail__canvas">
          <WorkInteractiveStage client:only="react" slug={entry.id}>
            <div
              slot="fallback"
              class="interactive-loading"
              role="status"
              aria-live="polite"
              aria-label="互動內容載入中"
            >
              <span class="interactive-loading__mark"></span>
            </div>
          </WorkInteractiveStage>
        </div>
        <p class="work-detail__canvas-scroll-hint" aria-hidden="true">上下滑動以瀏覽參數與文章</p>
      </div>
    ) : (
      <CanvasPlaceholder class="work-canvas" variant="unavailable" />
    )
  }

  <div class="container work-detail">
    <article class="prose work-detail__prose">
      <Content />
    </article>

    <nav class="work-detail__pager" aria-label="作品導覽">
      {
        previousWork ? (
          <a href={`/works/${previousWork.id}`} class="work-detail__pager-link">
            <span>較早一篇</span>
            <strong>{previousWork.data.title}</strong>
          </a>
        ) : (
          <span
            class="work-detail__pager-link work-detail__pager-link--disabled"
            aria-disabled="true"
            aria-label="沒有較早一篇"
          >
            <span>較早一篇</span>
            <strong>無</strong>
          </span>
        )
      }
      {
        nextWork ? (
          <a href={`/works/${nextWork.id}`} class="work-detail__pager-link work-detail__pager-link--next">
            <span>較新一篇</span>
            <strong>{nextWork.data.title}</strong>
          </a>
        ) : (
          <span
            class="work-detail__pager-link work-detail__pager-link--disabled work-detail__pager-link--next"
            aria-disabled="true"
            aria-label="沒有較新一篇"
          >
            <span>較新一篇</span>
            <strong>無</strong>
          </span>
        )
      }
    </nav>

    <a href="/works" class="back-link">← 返回作品集</a>
  </div>
  {
    interactive ? (
      <script is:inline>
        (function () {
  function bindWorkControlsAccordion() {
    document.querySelectorAll('[data-work-controls]').forEach(function (details) {
      if (details.dataset.workControlsBound) return;
      details.dataset.workControlsBound = 'true';
      var media = window.matchMedia('(min-width: 1024px)');
      var syncing = false;
      function syncOpenState() {
        syncing = true;
        if (media.matches) {
          details.open = true;
          details.dataset.workControlsUserToggled = '';
        } else if (!details.dataset.workControlsUserToggled) {
          details.open = false;
        }
        syncing = false;
      }
      syncOpenState();
      if (typeof media.addEventListener === 'function') {
        media.addEventListener('change', syncOpenState);
      } else if (typeof media.addListener === 'function') {
        media.addListener(syncOpenState);
      }
      details.addEventListener('toggle', function () {
        if (syncing) return;
        if (!syncing && !media.matches) {
          details.dataset.workControlsUserToggled = 'true';
        }
        if (!details.open || media.matches) return;
        var panel = details.querySelector('.controls-panel--stage');
        if (!panel) return;
        requestAnimationFrame(function () {
          var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          panel.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
        });
      });
    });
  }
  bindWorkControlsAccordion();
})();
      </script>
    ) : null
  }
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/withBase';
import CanvasPlaceholder from '../../components/CanvasPlaceholder.astro';
import WorkInteractiveStage from '../../components/works/WorkInteractiveStage';
import { getCollection, render } from 'astro:content';
import { getStaticPathsFromCollection } from '../../content/utils';
import {
  isWorkInteractive,
  workControlsMountId,
} from '../../works/interactiveRegistry';
import '../../styles/prose.css';
import '../../styles/pages/work-detail.css';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return getStaticPathsFromCollection(works);
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const interactive = isWorkInteractive(entry.id);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  {
    interactive ? (
      <div class="work-detail__stage">
        <div class="work-detail__canvas">
          <WorkInteractiveStage client:only="react" slug={entry.id} />
        </div>
        <aside
          class="controls-panel controls-panel--stage"
          id={workControlsMountId(entry.id)}
          aria-label="參數控制區"
        />
      </div>
    ) : (
      <CanvasPlaceholder class="work-canvas" variant="unavailable" />
    )
  }

  <div class="container work-detail">
    <h1 class="work-detail__title">{entry.data.title}</h1>

    <div class="tag-list">
      {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <article class="prose work-detail__prose">
      <Content />
    </article>

    <a href={withBase('/works')} class="back-link">← 返回作品集</a>
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/withBase';
import CanvasPlaceholder from '../../components/CanvasPlaceholder.astro';
import WorkInteractiveStage from '../../components/works/WorkInteractiveStage';
import { getCollection, render } from 'astro:content';
import { getPublishedAsc, getStaticPathsFromCollection } from '../../content/utils';
import {
  isWorkInteractive,
  workControlsMountId,
} from '../../works/interactiveRegistry';
import { getWorkOgImagePath } from '../../lib/workOgImage';
import 'katex/dist/katex.min.css';
import '../../styles/prose.css';
import '../../styles/pages/work-detail.css';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return getStaticPathsFromCollection(works);
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const interactive = isWorkInteractive(entry.id);
const works = getPublishedAsc(await getCollection('works'));
const workIndex = works.findIndex((work) => work.id === entry.id);
const previousWork = workIndex > 0 ? works[workIndex - 1] : null;
const nextWork = workIndex >= 0 && workIndex < works.length - 1 ? works[workIndex + 1] : null;
const ogImage = entry.data.ogImage ?? getWorkOgImagePath(entry.id);
const site = Astro.site ?? Astro.url;
const siteRoot = new URL(withBase('/'), site).href;
const worksUrl = new URL(withBase('/works'), site).href;
const articleUrl = new URL(withBase(`/works/${entry.id}`), site).href;
const imageUrl = new URL(withBase(ogImage), site).href;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: siteRoot },
      { '@type': 'ListItem', position: 2, name: '作品集', item: worksUrl },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: articleUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    image: imageUrl,
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    inLanguage: 'zh-Hant',
    datePublished: entry.data.date.toISOString(),
  },
];
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  ogImageAlt={entry.data.title}
  ogType="article"
  structuredData={structuredData}
>
  <div class="container work-detail__top-nav">
    <a href={withBase('/works')} class="back-link back-link--top">← 返回作品集</a>
  </div>

  {
    interactive ? (
      <div class="work-detail__stage">
        <div class="work-detail__canvas">
          <WorkInteractiveStage client:only="react" slug={entry.id}>
            <div
              slot="fallback"
              class="interactive-loading"
              role="status"
              aria-live="polite"
              aria-label="互動內容載入中"
            >
              <span class="interactive-loading__mark"></span>
            </div>
          </WorkInteractiveStage>
        </div>
        <aside
          class="controls-panel controls-panel--stage"
          id={workControlsMountId(entry.id)}
          aria-label="參數控制區"
        />
      </div>
    ) : (
      <CanvasPlaceholder class="work-canvas" variant="unavailable" />
    )
  }

  <div class="container work-detail">
    <h1 class="work-detail__title">{entry.data.title}</h1>

    <div class="tag-list">
      {entry.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <article class="prose work-detail__prose">
      <Content />
    </article>

    <nav class="work-detail__pager" aria-label="作品導覽">
      {
        previousWork ? (
          <a href={withBase(`/works/${previousWork.id}`)} class="work-detail__pager-link">
            <span>上一篇</span>
            <strong>{previousWork.data.title}</strong>
          </a>
        ) : (
          <span
            class="work-detail__pager-link work-detail__pager-link--disabled"
            aria-disabled="true"
            aria-label="沒有上一篇"
          >
            <span>上一篇</span>
            <strong>無</strong>
          </span>
        )
      }
      {
        nextWork ? (
          <a href={withBase(`/works/${nextWork.id}`)} class="work-detail__pager-link work-detail__pager-link--next">
            <span>下一篇</span>
            <strong>{nextWork.data.title}</strong>
          </a>
        ) : (
          <span
            class="work-detail__pager-link work-detail__pager-link--disabled work-detail__pager-link--next"
            aria-disabled="true"
            aria-label="沒有下一篇"
          >
            <span>下一篇</span>
            <strong>無</strong>
          </span>
        )
      }
    </nav>

    <a href={withBase('/works')} class="back-link">← 返回作品集</a>
  </div>
</BaseLayout>
